<Page x:Class="TournamentManager.Timovi"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TournamentManager"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Timovi - Runde">


    <Grid Background="{StaticResource PrimaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50*" />
            <ColumnDefinition Width="25*" />
            <ColumnDefinition Width="25*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="75*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Headers -->
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="2, 2, 2, 0">
            <Label HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="24" Foreground="{StaticResource PrimaryFontColor}">Timovi</Label>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 2, 2, 0">
            <Label HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="24" Foreground="{StaticResource PrimaryFontColor}">Score</Label>
        </Border>

        <Border Grid.Row="0" Grid.Column="2" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 2, 2, 0">
            <Label HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="24" Foreground="{StaticResource PrimaryFontColor}">Score diff</Label>
        </Border>

        <!-- Row 1: Team listing -->
        <Border Grid.Row="1" Grid.ColumnSpan="3"  BorderThickness="0, 2, 0, 2" BorderBrush="{StaticResource PrimaryFontColor}">
            <ScrollViewer Grid.ColumnSpan="3"  VerticalScrollBarVisibility="Hidden">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="25*" />
                        <ColumnDefinition Width="25*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="2, 0, 2, 0">
                        <ItemsControl  ItemsSource="{Binding AllTeams}" HorizontalAlignment="Center">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding Name}" Margin="0, 5, 0, 5" >
                                        <TextBlock.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Ažuriraj" Click="TeamUpdate_Click"/>
                                            </ContextMenu>
                                        </TextBlock.ContextMenu>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 0, 2, 0">
                        <ItemsControl ItemsSource="{Binding AllTeams}" HorizontalAlignment="Center">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding TeamTournamentScore}" Margin="0, 5, 0, 5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Border Grid.Column="2" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 0, 2, 0">
                        <ItemsControl ItemsSource="{Binding AllTeams}" HorizontalAlignment="Center">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding ScoreDifference}" Margin="0, 5, 0, 5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>


                </Grid>

            </ScrollViewer>
        </Border>
        
        <!-- Row 2: Dodaj tim button -->
        <Border Grid.Column="2" Grid.ColumnSpan="1" Grid.Row="2" CornerRadius="40"
             Margin="0, 10, 0, 10"
             BorderThickness="2"
             Background="{StaticResource ButtonBackgroundColor}" 
             BorderBrush="{StaticResource PrimaryFontColor}"  
             MouseLeftButtonDown="AddTeam_Click">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <!-- Hover effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.8" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="Dodaj tim" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                FontSize="24"
                Foreground="{StaticResource PrimaryFontColor}"/>
        </Border>

    </Grid>
</Page>
