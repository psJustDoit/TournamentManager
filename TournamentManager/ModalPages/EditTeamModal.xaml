<Window x:Class="TournamentManager.EditTeamModal"
        x:Name="EditTeamModalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TournamentManager"
        mc:Ignorable="d"
        Title="Ažuriraj tim" 
        Height="450" 
        Width="800"
        WindowStartupLocation="CenterOwner">

    <StackPanel Background="{StaticResource PrimaryBackgroundColor}" Orientation="Vertical">
        <!-- Team name -->
        <Label HorizontalAlignment="Center" Content="Ime tima:" Foreground="{StaticResource PrimaryFontColor}"/>
        <TextBox Width="200"  x:Name="TeamNameTextbox"
                   Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                   Height="30"/>

        <!-- City -->
        <Label HorizontalAlignment="Center" Content="Poslovnica:" Foreground="{StaticResource PrimaryFontColor}" Margin="0, 15, 0 , 0"/>
        <ComboBox x:Name="OfficeComboBox" ItemsSource="{Binding Offices, ElementName=EditTeamModalWindow}"
              Width="200"
              DisplayMemberPath="Name"
              SelectedItem="{Binding SelectedOffice}"/>
        <!--<TextBox Width="200" x:Name="TeamCityTextbox"
                   Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                   Height="30"
                   Margin="10"/>-->

        <!-- Wins -->
        <Label HorizontalAlignment="Center" Content="Wins / Losses / Draws:" Foreground="{StaticResource PrimaryFontColor}" Margin="0, 15, 0, 0"/>
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

            <Button Width="25" Height="25" Content="+" FontSize="15"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Click="IncrementTeamWins_Click"
                    Background="{StaticResource ButtonBackgroundColor}" 
                    Foreground="{StaticResource PrimaryFontColor}" 
                    BorderBrush="{StaticResource PrimaryFontColor}" />

            <TextBox Width="50" x:Name="TeamWinsTextbox"
               Text="{Binding Wins, UpdateSourceTrigger=PropertyChanged}"
               Height="30"
               Margin="10, 0, 10, 0"/>

            <Button Width="25" Height="25" Content="-" FontSize="15"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Click="SubtractTeamWins_Click"
                    Background="{StaticResource ButtonBackgroundColor}" 
                    Foreground="{StaticResource PrimaryFontColor}" 
                    BorderBrush="{StaticResource PrimaryFontColor}" />



            <Path Data="M 2,45 L 7,2" Stroke="{StaticResource PrimaryFontColor}" StrokeThickness="2" Margin="4,0" />


            <!-- Losses -->
            <Button Width="25" Height="25" Content="+" FontSize="15"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Click="IncrementTeamLosses_Click"
                    Background="{StaticResource ButtonBackgroundColor}" 
                    Foreground="{StaticResource PrimaryFontColor}" 
                    BorderBrush="{StaticResource PrimaryFontColor}" />

            <TextBox Width="50" x:Name="TeamLossesTextbox"
                Text="{Binding Draws, UpdateSourceTrigger=PropertyChanged}"
                Height="30"
                Margin="5, 0, 5, 0"/>

            <Button Width="25" Height="25" Content="-" FontSize="15"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Click="SubtractTeamLosses_Click"
                    Background="{StaticResource ButtonBackgroundColor}" 
                    Foreground="{StaticResource PrimaryFontColor}" 
                    BorderBrush="{StaticResource PrimaryFontColor}" />

            <Path Data="M 2,45 L 7,2" Stroke="{StaticResource PrimaryFontColor}" StrokeThickness="2" Margin="4,0" />

            <!-- Draws -->
            <Button Width="25" Height="25" Content="+" FontSize="15"
             VerticalAlignment="Center"
             HorizontalAlignment="Center"
             Click="IncrementTeamDraws_Click"
             Background="{StaticResource ButtonBackgroundColor}" 
             Foreground="{StaticResource PrimaryFontColor}" 
             BorderBrush="{StaticResource PrimaryFontColor}" />


            <TextBox Width="50" x:Name="TeamDrawsTextbox"
             Text="{Binding Losses, UpdateSourceTrigger=PropertyChanged}"
             Height="30"
             Margin="5, 0, 5, 0"/>

            <Button Width="25" Height="25" Content="-" FontSize="15"
             VerticalAlignment="Center"
             HorizontalAlignment="Center"
             Click="SubtractTeamDraws_Click"
             Background="{StaticResource ButtonBackgroundColor}" 
             Foreground="{StaticResource PrimaryFontColor}" 
             BorderBrush="{StaticResource PrimaryFontColor}" />

        </StackPanel>

        <!-- Team score -->
        <Label HorizontalAlignment="Center" Content="Score:" Foreground="{StaticResource PrimaryFontColor}" Margin="0, 15, 0, 0"/>
        <TextBox Width="200" x:Name="ScoreTextbox" 
               Text="{Binding TeamTournamentScore}"
               Height="30"
               Margin="10"/>

        <!-- Update button -->
        <Border BorderThickness="2" Width="100"
                  Background="{StaticResource ButtonBackgroundColor}"
                  CornerRadius="5"
                  BorderBrush="{StaticResource PrimaryFontColor}"
                  Margin="0, 15, 0, 0">
            <Button Content="Ažuriraj"
                  FontSize="20"
                  x:Name="UpdateTeamButton"
                  Click="UpdateTeam_Click"
                  Background="Transparent"
                  BorderThickness="0"
                  Foreground="{StaticResource PrimaryFontColor}"
                  FontWeight="Bold"/>
        </Border>
    </StackPanel>
</Window>
