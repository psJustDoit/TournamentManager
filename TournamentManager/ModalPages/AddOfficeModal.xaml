<Window x:Class="TournamentManager.AddOfficeModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dodaj poslovnicu"
        WindowStartupLocation="CenterOwner"
        Height="350"
        Width="400">

    <StackPanel Background="{StaticResource PrimaryBackgroundColor}" Orientation="Vertical">
        <Label HorizontalAlignment="Center" Content="Poslovnica:" Foreground="{StaticResource PrimaryFontColor}"/>
        <TextBox Width="200"  x:Name="OfficeNameTextbox"
                 Text="{Binding OfficeName, UpdateSourceTrigger=PropertyChanged}"
                 Height="30"
                 Margin="10"/>

        <Label HorizontalAlignment="Center" Content="Adresa:" Foreground="{StaticResource PrimaryFontColor}"/>
        <TextBox Width="200" x:Name="OfficeAddressTextbox"
                 Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                 Height="30"
                 Margin="10"/>

        <Label HorizontalAlignment="Center" Content="Dr&#382;ava:" Foreground="{StaticResource PrimaryFontColor}"/>
        <ComboBox Width="200" x:Name="CountriesCombobox"
                  ItemsSource="{Binding Countries}"
                  DisplayMemberPath="CountryName"
                  SelectedValuePath="CountryId"
                  Height="30"
                  Margin="10"/>

        <Border BorderThickness="2" Width="100"
                Background="{StaticResource ButtonBackgroundColor}"
                CornerRadius="5"
                BorderBrush="{StaticResource PrimaryFontColor}"
                Margin="0, 5, 0, 0">
            <Button Content="Dodaj"
                x:Name="AddOfficeButton"
                Click="DodajPoslovnicu_Click"
                BorderThickness="0"
                IsDefault="True"
                FontSize="20"
                Background="Transparent"
                Foreground="{StaticResource PrimaryFontColor}"
                FontWeight="Bold"/>
        </Border>

    </StackPanel>

</Window>
