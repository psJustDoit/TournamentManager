<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TournamentManager"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="TournamentManager.MainWindow"
        Closing="MainWindow_Close"
        mc:Ignorable="d"
        Title="Tournament Manager" MinWidth="700" MinHeight="500" Background="White" FontWeight="Bold" ResizeMode="NoResize">

    <Grid Background="#FF1A1A1F">
        <Grid.ColumnDefinitions>
            <!-- 10% -->
            <ColumnDefinition Width="12*"/>
            <!-- 90% -->
            <ColumnDefinition Width="88*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="{StaticResource ButtonBackgroundColor}" Orientation="Vertical">
            <Border />
            <Menu Background="Transparent">
                <Menu.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </Menu.ItemsPanel>

                <MenuItem Margin="0, 8, 0, 0"
                          Click="Navigation_PoslovniceClick">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                                <Image Source="/Icons/poslovnice.png" 
                                   Width="24" Height="24"
                                   Margin="0,0,10,0"/>
                                <TextBlock Text="Poslovnice"
                                           Foreground="{StaticResource PrimaryFontColor}"  
                                           FontSize="24"
                                           Margin="5,2,10,2"
                                           Padding="3,1,3,1"
                                           FontWeight="Bold"/>
                            </StackPanel>
                    </MenuItem.Header>
                </MenuItem>

                <MenuItem Margin="0, 15, 0, 0" Click="Navigation_TimoviClick">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Icons/timovi.png" 
                                   Width="24" Height="24" 
                                   Margin="0,0,10,0"/>
                            <TextBlock Text="Timovi"
                                       Foreground="{StaticResource PrimaryFontColor}"
                                       FontSize="24"
                                       Margin="5,2,10,2"
                                       Padding="3,1,3,1"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>

                <MenuItem Margin="0, 15, 0, 0" Click="Navigation_TurnirClick">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Icons/runde.png" 
                                   Width="24" Height="24" 
                                   Margin="0,0,10,0"/>
                            <TextBlock Text="Turnir" 
                                           Foreground="{StaticResource PrimaryFontColor}"
                                           FontSize="24"
                                           Margin="5,2,10,2"
                                           Padding="3,1,3,1"
                                           FontWeight="Bold"/>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>

            </Menu>
        </StackPanel>

       
        <Label Grid.Column="1" 
               Margin="5, 0, 5, 0"
               VerticalAlignment="Center" 
               HorizontalAlignment="Center"
               FontSize="70" 
               Foreground="{StaticResource PrimaryFontColor}">
            <TextBlock Text="Welcome! Let's host a tournament." TextWrapping="Wrap"/>
        </Label>
        

        <!-- Content Area with Frame -->
        <Frame x:Name="MainContentFrame" 
        Grid.Column="1"
        NavigationUIVisibility="Hidden"/>
    </Grid>

</Window>
