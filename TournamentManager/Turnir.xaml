<Page x:Class="TournamentManager.Turnir"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TournamentManager"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Turnir">
    <Page.Resources>
        <local:ElementVisibilityConverter x:Key="ElementVisibility" />
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80*"/>
            <ColumnDefinition  Width="20*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{StaticResource PrimaryFontColor}" Margin="5, 0, 0, 0" BorderThickness="0, 1, 2, 2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*" />
                    <ColumnDefinition Width="50*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="50*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Turnir label -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center" 
                               HorizontalAlignment="Left" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource PrimaryFontColor}"
                               Margin="5, 0, 0, 0">
                        <Underline>Turnir</Underline>
                    </TextBlock>
                    
                    <!-- Round count, start time -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Runda:" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="15" Margin="0, 0, 5, 0"  Foreground="{StaticResource PrimaryFontColor}"/>
                        <TextBlock Text="{Binding RoundCount}" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="15" Foreground="{StaticResource PrimaryFontColor}"/>
                    </StackPanel>
                    
                </Grid>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Vrijeme početka:" Foreground="{StaticResource PrimaryFontColor}" FontSize="15" VerticalAlignment="Center" Margin="0, 0, 5, 0"/>
                    <TextBlock Text="{Binding RoundStartDateTime}" Foreground="{StaticResource PrimaryFontColor}" FontSize="15" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Start tournament && next round button -->
        <Border Grid.Column="2" Grid.Row="0" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 0, 0, 2">
            <Border CornerRadius="40"
                 Margin="15, 5, 15, 5"
                 BorderThickness="2"
                 Background="{StaticResource ButtonBackgroundColor}" 
                 BorderBrush="{StaticResource PrimaryFontColor}"  
                 MouseLeftButtonDown="StartTournament_Click">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!-- Hover effect -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Start turnir" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    FontSize="24"
                    Foreground="{StaticResource PrimaryFontColor}"/>
            </Border>
        </Border>
        <!-- END HEADER -->

        <!-- Team pairings -->
        <Border Grid.Row="1" Grid.Column="0">
            
            <!-- First match listing -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10*" />
                    <RowDefinition Height="90*" />
                </Grid.RowDefinitions>

                <!-- Prva runda header -->
                <TextBlock Grid.Row="0" Grid.ColumnSpan="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20"><Underline>Prva runda</Underline></TextBlock>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="10*" />
                            <ColumnDefinition Width="35*" />
                            <ColumnDefinition Width="10*" />
                            <ColumnDefinition Width="35*" />
                            <ColumnDefinition Width="10*" />
                        </Grid.ColumnDefinitions>

                        <!-- Listing team pairs -->
                        <ItemsControl Grid.Column="1" Grid.ColumnSpan="3" ItemsSource="{Binding FirstRoundPairings}" >
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0, 5, 0, 5" >
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40*" />
                                            <ColumnDefinition Width="20*" />
                                            <ColumnDefinition Width="40*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Team1 vs. Team2-->
                                        <Border Grid.Column="0" Background="{StaticResource ButtonBackgroundColor}" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="2" CornerRadius="5" HorizontalAlignment="Stretch">
                                            <TextBlock FontSize="15" Foreground="{StaticResource PrimaryFontColor}" Text="{Binding Team1.Name}" HorizontalAlignment="Center" />
                                        </Border>

                                        <TextBlock Grid.Column="1" Foreground="{StaticResource PrimaryFontColor}" FontSize="15" Text="vs." HorizontalAlignment="Center" />

                                        <Border Grid.Column="2" Background="{StaticResource ButtonBackgroundColor}" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="2" CornerRadius="5" HorizontalAlignment="Stretch">
                                            <TextBlock FontSize="15" Foreground="{StaticResource PrimaryFontColor}" Text="{Binding Team2.Name}" HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                       
                        
                    </Grid>
                </ScrollViewer>
            </Grid>
            
            
        </Border>

    </Grid>
</Page>

