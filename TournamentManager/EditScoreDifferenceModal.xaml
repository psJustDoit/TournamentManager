<Window x:Class="TournamentManager.EditScoreDifferenceModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TournamentManager"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="EditScoreDifferenceModal" Height="450" Width="800">
    
    <Grid Background="{StaticResource PrimaryBackgroundColor}">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding Team1.Name}"/>
                <TextBox HorizontalAlignment="Center" Width="200" x:Name="Team1GameMatchScore" Height="30" Margin="10"/>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0, 20, 0, 0">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding Team2.Name}"/>
                <TextBox HorizontalAlignment="Center" Width="200" x:Name="Team2GameMatchScore" Height="30" Margin="10"/>
            </StackPanel>

            <Border BorderThickness="1" Width="100"
                 Background="{StaticResource ButtonBackgroundColor}"
                 CornerRadius="5"
                 BorderBrush="{StaticResource PrimaryFontColor}"
                 Margin="0, 5, 0, 0">
                <Button Content="OK"
                     x:Name="ButtonOK"
                     Click="ButtonOK_Click"
                     IsDefault="True"
                     Background="Transparent"
                     FontSize="20"
                     BorderThickness="0"
                     Foreground="{StaticResource PrimaryFontColor}"
                     FontWeight="Bold"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
