<Window x:Class="TournamentManager.EditPoslovnicaModal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TournamentManager"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="Ažuriraj poslovnicu" Height="450" Width="800">

    <Grid Background="{StaticResource PrimaryBackgroundColor}">
        <StackPanel Background="#FF1A1A1F" Orientation="Vertical">
            <Label HorizontalAlignment="Center" Content="Poslovnica:" Foreground="#bac0e6"/>
            <TextBox Width="200"  x:Name="OfficeNameTextbox"
             Text="{Binding OfficeName, UpdateSourceTrigger=PropertyChanged}"
             Height="30"
             Margin="10"/>

            <Label HorizontalAlignment="Center" Content="Adresa:" Foreground="#bac0e6"/>
            <TextBox Width="200" x:Name="OfficeAddressTextbox"
             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
             Height="30"
             Margin="10"/>

            <Label HorizontalAlignment="Center" Content="Država:" Foreground="{StaticResource PrimaryFontColor}"/>
            <ComboBox Width="200" x:Name="OfficeCountryCombobox"
              ItemsSource="{Binding Countries}"
              DisplayMemberPath="CountryName"
              SelectedValuePath="CountryId"
              SelectedValue="{Binding SelectedCountryId, Mode=TwoWay}"
              Height="30"
              Margin="10"/>

            <Border BorderThickness="2" Width="100"
                Background="{StaticResource ButtonBackgroundColor}"
                BorderBrush="{StaticResource PrimaryFontColor}"
                CornerRadius="5"
                Margin="0, 5, 0, 0">
                <Button Content="Edit"
                    Width="100"
                    x:Name="AddOfficeButton"
                    FontSize="20"
                    Click="EditPoslovnicu_Click"
                    BorderThickness="0"
                    Background="Transparent"
                    Foreground="{StaticResource PrimaryFontColor}"
                    FontWeight="Bold"/>
                
            </Border>

        </StackPanel>
    </Grid>
</Window>
