<Page x:Class="TournamentManager.RoundHistory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TournamentManager"
      xmlns:converters="clr-namespace:TournamentManager.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Runde - History">
    <Page.Resources>
        <converters:OutcomeToColorConverter x:Key="OutcomeToColorConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource PrimaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70*"/>
            <ColumnDefinition Width="30*"/>
        </Grid.ColumnDefinitions>

        <!-- PAIRS AND ROUND SELECTION -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="5*"/>
                <RowDefinition Height="70*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Column="0" Grid.Row="0" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 0, 1, 1">
                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryFontColor}" Margin="20, 0 ,0 ,0" VerticalAlignment="Center"><Underline>Prethodne runde</Underline></TextBlock>
            </Border>

            <!-- Selected round -->
            <Border Grid.Row="1" Grid.Column="0" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 1, 1, 1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50*" />
                        <ColumnDefinition Width="50*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="20, 0, 0 , 0" Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Odabrana runda: " Foreground="{StaticResource PrimaryFontColor}" FontSize="15"/>
                        <ComboBox x:Name="RoundToViewSelect" ItemsSource="{Binding Rounds}"
                              Width="150"
                              SelectedItem="{Binding SelectedRound}"
                              SelectionChanged="SelectedRound_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="Završena: " Foreground="{StaticResource PrimaryFontColor}" FontSize="15"/>
                        <TextBlock Text="{Binding RoundToView.DateTimeEnded}" Foreground="{StaticResource PrimaryFontColor}" FontSize="15"/>
                    </StackPanel>
                </Grid>
                
            </Border>

            <!-- Pairs in selected round -->
            <Border Grid.Row="2" Grid.Column="0" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 1, 1, 2">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" Margin="20, 20, 20, 0">
                    <!-- Listing team pairs -->
                    <ItemsControl Grid.Column="1" Grid.ColumnSpan="3" ItemsSource="{Binding RoundToView.TeamPairing}" >
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="2" CornerRadius="5" Background="{StaticResource ButtonBackgroundColor}" Margin="0, 0 ,0, 20">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="5*"/>
                                            <ColumnDefinition Width="95*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Team 1 -->
                                        <Border Grid.Column="0" Grid.Row="0" BorderBrush="{StaticResource PrimaryFontColor}" 
                                                BorderThickness="0, 0, 0, 1" Background="{Binding Team1, Converter={StaticResource OutcomeToColorConverter}}">
                                        </Border>

                                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 0, 2, 1">
                                            <TextBlock HorizontalAlignment="Stretch" VerticalAlignment="Center" FontSize="20" Foreground="{StaticResource PrimaryFontColor}" Text="{Binding Team1.Name}" Margin="5, 0, 0, 0"/>
                                        </Border>

                                        <!-- Team 2 -->
                                        <Border Grid.Column="0" Grid.Row="1" BorderBrush="{StaticResource PrimaryFontColor}" 
                                                BorderThickness="0, 1, 0, 0" Background="{Binding Team2, Converter={StaticResource OutcomeToColorConverter}}">
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="0, 1, 2, 0" HorizontalAlignment="Stretch">
                                            <TextBlock HorizontalAlignment="Stretch" VerticalAlignment="Center" FontSize="20" Foreground="{StaticResource PrimaryFontColor}" Text="{Binding Team2.Name}" Margin="5, 0, 0, 0"/>
                                        </Border>

                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </ScrollViewer>
            </Border>
        </Grid>
        <!-- END PAIRS AND ROUND SELECTION -->


        <!-- SCOREBOARD -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="90*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="1, 0, 0, 1">
                <TextBlock Text="Scoreboard" Foreground="{StaticResource PrimaryFontColor}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Row="1"  BorderBrush="{StaticResource PrimaryFontColor}" BorderThickness="1, 1, 0, 2">
                <Grid x:Name="Scoreboard">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="15*" />
                        <ColumnDefinition Width="70*" />
                        <ColumnDefinition Width="15*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5*"/>
                        <RowDefinition Height="95*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20"><Underline>Score</Underline></TextBlock>
                    <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20"><Underline>Ime</Underline></TextBlock>
                    <TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20"><Underline>Diff</Underline></TextBlock>

                    <ScrollViewer VerticalScrollBarVisibility="Hidden" Grid.Row="1" Grid.ColumnSpan="3">
                        <ItemsControl ItemsSource="{Binding RoundToView.Scoreboard}" >
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0, 5, 0 ,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="15*" />
                                            <ColumnDefinition Width="70*" />
                                            <ColumnDefinition Width="15*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding TournamentScore}"/>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding TeamDisplayName}"/>
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryFontColor}" FontSize="20" Text="{Binding ScoreDifference}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
        <!-- END SCOREBOARD -->

    </Grid>
</Page>
