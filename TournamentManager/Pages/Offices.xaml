<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:TournamentManager.ViewModels"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="TournamentManager.Offices"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Poslovnice">

    <Grid Background="{StaticResource PrimaryBackgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20*"/>
            <ColumnDefinition Width="60*"/>
            <ColumnDefinition Width="20*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="10*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="92*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border VerticalAlignment="Center" Grid.Column="0" Grid.Row="0" BorderBrush="{StaticResource PrimaryFontColor}" 
                CornerRadius="5"
                Padding="1"
                Margin="5, 15, 10, 0"
                Height="80"
                Background="Transparent"
                HorizontalAlignment="Left">
            <Label FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Poslovnice" 
                        TextDecorations="Underline"
                        FontWeight="Bold" 
                        Foreground="{StaticResource PrimaryFontColor}" />
            </Label>
        </Border>

        <Border VerticalAlignment="Center" Grid.Column="2" BorderBrush="{StaticResource PrimaryFontColor}" 
                BorderThickness="4" 
                CornerRadius="15"
                Margin="10, 15, 10, 0"
                Width="240"
                Height="80"
                Background="{StaticResource ButtonBackgroundColor}"
                HorizontalAlignment="Right"    
                MouseLeftButtonDown="DodajPoslovnicu_Click">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.8" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >
                <Image Source="/Icons/plus.png" Width="24" Height="24" Margin="0,0,5,0"/>
                <TextBlock Text="Dodaj poslovnicu" VerticalAlignment="Center" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryFontColor}"/>
            </StackPanel>

        </Border>

        <Separator VerticalAlignment="Center" Grid.Row="1" Grid.ColumnSpan="3" Margin="10,0,10,10" Background="{StaticResource PrimaryFontColor}" Height="15"/>

        <!-- Poslovnice i drzave content -->
        <!-- Drzave list -->
        <!--<Grid Grid.Row="2" Margin="1, 0, 0, 1" Grid.ColumnSpan="3">-->
        <ListBox Grid.Row="2" Grid.ColumnSpan="3" ItemsSource="{Binding CountriesToDisplay}" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Grid.ColumnSpan="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" HorizontalAlignment="Left" Text="{Binding CountryName}" FontSize="24" Foreground="{StaticResource PrimaryFontColor}"/>

                        <!--<Separator Grid.Row="1" Margin="250,1,250,1"
                                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                Background="{StaticResource PrimaryFontColor}"
                                Height="15"/>-->
                        <Rectangle Grid.Row="1" 
                           Height="2" 
                           Grid.ColumnSpan="3"
                           Margin="5"
                           HorizontalAlignment="Stretch"
                           Fill="{StaticResource PrimaryFontColor}"/>

                        <!-- Offices by country -->
                        <ItemsControl Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Center" ItemsSource="{Binding Offices}">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource PrimaryFontColor}"
                                             Background="{StaticResource ButtonBackgroundColor}"
                                             BorderThickness="1"
                                             CornerRadius="3"
                                             Padding="10"
                                             Margin="5">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Edit" Click="EditOffice_Click"/>
                                                <MenuItem Header="Delete" Click="DeleteOffice_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <TextBlock Text="{Binding Name}"  Foreground="{StaticResource PrimaryFontColor}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </Grid>

                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>
        <!--</Grid>-->

    </Grid>
</Page>
